# Django Configuration
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_SECRET_KEY=change-this-to-a-very-long-random-secret-key-min-50-chars
DEBUG=False

# Database Configuration
# For PostgreSQL (production)
DATABASE_URL=postgresql://admin:secure_password@localhost:5432/academic_system
# For SQLite (development only - comment out DATABASE_URL above)
# DATABASE_URL=sqlite:///db.sqlite3

# Allowed Hosts (comma-separated, required for production)
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# Security Settings
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Optional: Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password

# Logging
LOG_LEVEL=INFO
