{
  "buildCommand": "pip install -r requirements.txt && cd Django-Project/config && python manage.py collectstatic --noinput --clear",
  "outputDirectory": "Django-Project/config/staticfiles",
  "devCommand": "cd Django-Project/config && python manage.py runserver 0.0.0.0:8000",
  "framework": "django",
  "python": {
    "version": "3.13"
  },
  "env": {
    "DJANGO_SETTINGS_MODULE": "config.settings",
    "DEBUG": "False"
  },
  "envVars": [
    {
      "key": "DJANGO_SECRET_KEY",
      "description": "Django secret key for production"
    },
    {
      "key": "DATABASE_URL",
      "description": "PostgreSQL database URL"
    },
    {
      "key": "ALLOWED_HOSTS",
      "description": "Comma-separated allowed hosts"
    }
  ],
  "builds": [
    {
      "src": "wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "wsgi.py"
    }
  ]
}

